{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "rewrites": [
    { "source": "/app", "destination": "https://loraloop-main-api.vercel.app/" },
    { "source": "/app/:path*", "destination": "https://loraloop-main-api.vercel.app/:path*" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
